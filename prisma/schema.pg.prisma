generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ========== ENUMS ==========

enum LifecycleStatus {
  DRAFT
  DESIGNING
  READY
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MaterialType {
  BEAD
  METAL
  CERAMIC
  LEATHER
  INCENSE
  CORD
  PACKAGING
  OTHER
}

enum TransactionType {
  IN
  OUT
  ADJUST
}

/// ========== 用户认证系统 ==========

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String
  role             String    @default("admin") // admin / staff / viewer
  name             String?
  avatar           String?   // 头像URL 或 base64
  permissions      String?   // JSON: 细粒度权限
  resetToken       String?   @map("reset_token")   // 密码重置令牌
  resetTokenExpiry DateTime?  @map("reset_token_expiry") // 令牌过期时间
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  @@map("users")
}

/// ========== 产品体系 ==========

model Series {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  name        String
  sortOrder   Int        @default(0) @map("sort_order")
  works       Works[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  @@map("series")
}

model Works {
  id          Int             @id @default(autoincrement())
  code        String          @unique
  name        String
  seriesId    Int             @map("series_id")
  series      Series          @relation(fields: [seriesId], references: [id])
  status      LifecycleStatus  @default(DESIGNING)
  products    Products[]
  assets      WorksAssets?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  @@map("works")
}

model WorksAssets {
  id              Int      @id @default(autoincrement())
  workId          Int      @unique @map("work_id")
  work            Works    @relation(fields: [workId], references: [id])
  story           String?
  designConcept   String?  @map("design_concept")
  thumbnail       String?
  gallery         String?
  videoUrl        String?  @map("video_url")
  quote           String?
  launchDate      DateTime? @map("launch_date")
  @@map("works_assets")
}

model Products {
  id           Int              @id @default(autoincrement())
  code         String           @unique
  name         String
  workId       Int              @map("work_id")
  work         Works            @relation(fields: [workId], references: [id])
  status       LifecycleStatus  @default(DESIGNING)
  description  String?
  skus         ProductSku[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  @@map("products")
}

model ProductSku {
  id               Int              @id @default(autoincrement())
  code             String           @unique
  name             String
  productId        Int              @map("product_id")
  product          Products         @relation(fields: [productId], references: [id])
  status           LifecycleStatus  @default(DESIGNING)

  specification     String?          @default("") @map("specification")
  size             String?          @default("")

  price            Float            @default(0)
  finishedStock     Int              @default(0) @map("finished_stock")

  markupRatio       Float?           @default(1.0) @map("markup_ratio")
  rarityLevel       Int?             @default(1) @map("rarity_level")
  storyFactor       Float?           @default(1.0) @map("story_factor")

  cost             ProductCost?
  boms             Bom[]

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  @@map("product_skus")
}

model ProductCost {
  id              Int         @id @default(autoincrement())
  skuId           Int         @unique @map("sku_id")
  sku             ProductSku  @relation(fields: [skuId], references: [id])
  materialCost     Float       @default(0) @map("material_cost")
  laborCost        Float       @default(0) @map("labor_cost")
  totalCost        Float       @default(0) @map("total_cost")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  @@map("product_costs")
}

/// ========== 材料资产体系 ==========

model RawMaterial {
  id                     Int                @id @default(autoincrement())
  code                   String             @unique
  name                   String
  category               String             @default("")
  materialType           MaterialType       @default(OTHER)
  specification          String?            @default("") @map("specification")

  inventoryUnit          String             @default("颗")

  remaining              Float              @default(0)
  unitCost               Float?

  status                 LifecycleStatus    @default(READY)

  shape                  String?            @default("")
  beadsPerStrand         Int?               @default(0) @map("beads_per_strand")
  weightPerStrand        Float?             @default(0) @map("weight_per_strand")

  defaultPurchaseUnit     String?           @default("个") @map("default_purchase_unit")
  defaultConversionRate   Float?            @default(1)   @map("default_conversion_rate")

  supplier               String             @default("")
  remark                 String?            @default("")

  purchaseRecords        PurchaseRecord[]
  transactions           InventoryTransaction[]
  bomItems               Bom[]

  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  @@map("raw_materials")
}

model PurchaseRecord {
  id                     Int          @id @default(autoincrement())
  materialId             Int
  material               RawMaterial  @relation(fields: [materialId], references: [id])

  purchaseDate           DateTime      @default(now()) @map("purchase_date")
  supplier               String?

  purchaseUnit           String
  conversionRate         Float
  purchaseQuantity       Float
  purchaseUnitPrice      Float?       @map("purchase_unit_price")
  purchasePrice          Float
  inventoryQuantity      Float        @map("inventory_quantity")
  unitCost               Float?

  remark                 String?
  createdAt              DateTime      @default(now()) @map("created_at")
  @@map("purchase_records")
}

model InventoryTransaction {
  id                     Int              @id @default(autoincrement())
  materialId             Int
  material               RawMaterial     @relation(fields: [materialId], references: [id])

  type                   TransactionType
  quantity               Float
  beforeQty              Float
  afterQty               Float

  relatedDoc             String?        @map("related_doc")
  remark                 String?

  createdAt              DateTime         @default(now()) @map("created_at")
  @@map("inventory_transactions")
}

model Bom {
  id                         Int         @id @default(autoincrement())
  skuId                     Int         @map("sku_id")
  sku                        ProductSku  @relation(fields: [skuId], references: [id])
  materialId                 Int         @map("material_id")
  material                   RawMaterial  @relation(fields: [materialId], references: [id])

  quantity                   Float
  unitPrice                  Float?
  lineCost                   Float?      @map("line_cost")

  materialCodeSnapshot       String      @map("material_code_snapshot")
  materialNameSnapshot       String      @map("material_name_snapshot")

  @@unique([skuId, materialId])
  @@map("bom")
}
